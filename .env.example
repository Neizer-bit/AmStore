# Demo mode. `true` serves an embedded mock (no backend, no mock process) —
# use it for the Vercel client demo. `false` (or unset) = live mode.
NEXT_PUBLIC_DEMO_MODE=true

# Your tenant public key. Get it from the desk's Developers tab.
# `cpk_live_*` / `cpk_test_*` keys auto-route same-origin requests to hosted
# Cimplify. Ignored while NEXT_PUBLIC_DEMO_MODE=true. To go live, set demo mode
# false and paste a real cpk_live_ key here.
NEXT_PUBLIC_CIMPLIFY_PUBLIC_KEY=mock-dev

# Optional. Forces a fixed canonical URL for sitemap.xml, robots.txt,
# OpenGraph, and llms.txt. Leave unset and the storefront derives the
# canonical from the request `Host` header automatically.
# NEXT_PUBLIC_SITE_URL=
